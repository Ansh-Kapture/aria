# ── Provider selection ────────────────────────────────────────────────────────
# "auto" picks the first configured provider: vertexai > openai > anthropic
# Explicit options: anthropic | openai | openai_compatible | vertexai
LLM_PROVIDER=auto

# ── Option 1: Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Models used (defaults shown):
# ORCHESTRATOR_MODEL=claude-sonnet-4-6
# FAST_MODEL=claude-haiku-4-5-20251001

# ── Option 2: OpenAI ──────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_FAST_MODEL=gpt-4o-mini

# ── Option 3: OpenAI-compatible self-hosted endpoint ─────────────────────────
# Works with: Ollama, vLLM, LM Studio, Together AI, Groq, Anyscale, etc.
#
# Ollama (local):
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2
# OPENAI_FAST_MODEL=llama3.2
#
# vLLM (local):
# OPENAI_API_KEY=EMPTY
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# OPENAI_FAST_MODEL=mistralai/Mistral-7B-Instruct-v0.2
#
# Together AI:
# OPENAI_API_KEY=your-together-key
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_MODEL=meta-llama/Llama-3-70b-chat-hf
# OPENAI_FAST_MODEL=meta-llama/Llama-3-8b-chat-hf
#
# Groq:
# OPENAI_API_KEY=your-groq-key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# OPENAI_FAST_MODEL=llama-3.1-8b-instant

# ── Option 4: Vertex AI ───────────────────────────────────────────────────────
# VERTEX_PROJECT=my-gcp-project-id
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-pro
# VERTEX_FAST_MODEL=gemini-1.5-flash
#
# Credentials — choose ONE of:
#   a) Paste the full service-account JSON as a single-line string:
#      VERTEX_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}
#
#   b) Point to a file on disk:
#      VERTEX_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
#
#   c) Use Application Default Credentials (leave both blank):
#      Works automatically inside GCP (Cloud Run, GCE) or after:
#      gcloud auth application-default login

# ── Web search (optional, falls back to DuckDuckGo) ──────────────────────────
# TAVILY_API_KEY=tvly-...
# USE_TAVILY=false

# ── Orchestration (optional overrides) ───────────────────────────────────────
# QUALITY_THRESHOLD=6.5
# MAX_REPLAN_CYCLES=3
# MAX_PARALLEL_AGENTS=4
# GLOBAL_TIMEOUT_SECONDS=600
